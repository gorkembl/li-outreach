# Copy to .env for local development. Never commit the real .env file.

# Google Sheet ID (from URL)
SHEET_ID=1awtHQEg7G6AbGOAgwgw3OyhKwAT1M27yTKfIHNQmOS8

# Full contents of the service account JSON file, as a single line
# Tip: paste it inside single quotes
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}'

# ConnectSafely API key (from their dashboard)
CS_API_KEY=cs_...

# Anthropic API key (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Optional tuning (defaults shown)
DAILY_NEW_LEADS=5
DAILY_TOTAL_ACTIONS=40
DRY_RUN=false
